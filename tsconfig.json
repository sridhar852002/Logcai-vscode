{
	"compilerOptions": {
	  "target": "ES2022",
	  "module": "NodeNext",
	  "moduleResolution": "NodeNext",
	  "lib": ["DOM", "ES2022"],
	  "jsx": "react-jsx",
	  "rootDir": "src",
	  "outDir": "out",
	  "strict": true,
	  "esModuleInterop": true,
	  "resolveJsonModule": true,
	  "allowSyntheticDefaultImports": true,
	  "skipLibCheck": true,
	  "types": ["node", "vscode", "mocha"],
	  "typeRoots": ["./node_modules/@types", "./src/types"],
  
	  // ✅ ADD THIS:
	  "baseUrl": "./src",
	  "paths": {
		"@/*": ["*"]
	  }
	},
	"include": ["src", "src/types"]
  }
  